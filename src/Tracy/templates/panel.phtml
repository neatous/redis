<?php

declare(strict_types=1);

/**
 * @var list<array{name: string, server: string, database: int, prefix: string, persistent: bool, connected: bool, ping: ?float, dbSize: ?int, memory: ?string}> $connections
 */

?>
<h1>
	<svg viewBox="0 0 32 32" width="16" height="16" style="vertical-align: -2px; margin-right: 4px;">
		<path fill="#d93a2e" d="M30.4 18.5c-2.1 1.1-13 5.6-15.3 6.8-2.3 1.2-3.6 1.2-5.4.3S2.5 21.8.5 20.6v3.8c0 0 6.5 3.5 9.2 4.8s3.1.9 5.4-.3 13.2-5.7 15.3-6.8v-3.6z"/>
		<path fill="#d93a2e" d="M30.4 13.7c-2.1 1.1-13 5.6-15.3 6.8-2.3 1.2-3.6 1.2-5.4.3S2.5 17 .5 15.8v3.8c0 0 6.5 3.5 9.2 4.8s3.1.9 5.4-.3 13.2-5.7 15.3-6.8v-3.6z"/>
		<path fill="#d93a2e" d="M30.4 9c-2.1 1.1-13 5.6-15.3 6.8-2.3 1.2-3.6 1.2-5.4.3S2.5 12.3.5 11.1l9.2-4.2c2.7-1.3 3.1-.9 5.4.3S28.3 7.9 30.4 9z"/>
	</svg>
	Redis
</h1>

<div class="tracy-inner">
<?php foreach ($connections as $i => $conn): ?>
	<?php if ($i > 0): ?><br><?php endif ?>

	<table class="tracy-sortable" style="min-width: 320px;">
		<caption><?= htmlspecialchars($conn['name'], ENT_QUOTES, 'UTF-8') ?></caption>
		<tr>
			<th>Status</th>
			<td>
				<?php if ($conn['connected']): ?>
					<span style="color: #52be80; font-weight: bold;">● Connected</span>
				<?php else: ?>
					<span style="color: #e74c3c; font-weight: bold;">● Disconnected</span>
				<?php endif ?>
			</td>
		</tr>
		<tr>
			<th>Server</th>
			<td><code><?= htmlspecialchars($conn['server'], ENT_QUOTES, 'UTF-8') ?></code></td>
		</tr>
		<tr>
			<th>Database</th>
			<td><?= $conn['database'] ?></td>
		</tr>
		<tr>
			<th>Prefix</th>
			<td><code><?= htmlspecialchars($conn['prefix'], ENT_QUOTES, 'UTF-8') ?></code></td>
		</tr>
		<tr>
			<th>Persistent</th>
			<td><?= $conn['persistent'] ? 'Yes' : 'No' ?></td>
		</tr>
		<?php if ($conn['ping'] !== null): ?>
		<tr>
			<th>Ping</th>
			<td><?= $conn['ping'] ?> ms</td>
		</tr>
		<?php endif ?>
		<?php if ($conn['dbSize'] !== null): ?>
		<tr>
			<th>Keys</th>
			<td><?= number_format($conn['dbSize']) ?></td>
		</tr>
		<?php endif ?>
		<?php if ($conn['memory'] !== null): ?>
		<tr>
			<th>Memory</th>
			<td><?= htmlspecialchars($conn['memory'], ENT_QUOTES, 'UTF-8') ?></td>
		</tr>
		<?php endif ?>
	</table>
<?php endforeach ?>
</div>
